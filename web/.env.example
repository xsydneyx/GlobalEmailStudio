# Copy this file to .env and set values as needed.

# API base URL for templates/locations (e.g. http://localhost:3001). Required; app shows an error when unset.
VITE_API_URL=

# Google Cloud Translation API key for Save & translate (client calls Google directly).
# Create a key at https://console.cloud.google.com/apis/credentials and enable Cloud Translation API.
# Restrict the key by "HTTP referrer" (e.g. http://localhost:5173/*, https://yourdomain.com/*) so it can't be used from other sites.
VITE_GOOGLE_TRANSLATE_API_KEY=
